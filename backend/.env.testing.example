# 測試環境 .env 範本（複製到 .env.testing 後依本機環境調整）
#
# PR-Revert (2026-05-03)：測試環境改用 MySQL，與 production 一致。
# 詳見 docs/decisions/2026-05-03-test-environment-mysql-migration.md
#
# 注意：phpunit.xml + tests/CreatesApplication.php 內已注入這些值，
# 此檔案僅供 IDE / artisan tinker --env=testing / 文件參考用。

APP_ENV=testing
APP_DEBUG=true
APP_KEY=base64:Vghi6lFfFa8dMu3eYrM+PxKRq+u6SRrwbjQs8aXwL7g=

# ─── Database（必須與 production 同 driver = MySQL）─────────────
# 預設指向 docker-compose.yml 的 mimeet-mysql container，並使用
# 獨立 mimeet_test database（不污染 dev 資料）
DB_CONNECTION=mysql
DB_HOST=mysql              # docker-compose service name；host machine 直跑請改 127.0.0.1
DB_PORT=3306
DB_DATABASE=mimeet_test
DB_USERNAME=root
DB_PASSWORD=root_secret_2024

# ─── 其餘 services 用 array / sync / null（不依賴外部）──────────
CACHE_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
SESSION_DRIVER=array
BROADCAST_DRIVER=null

BCRYPT_ROUNDS=4
