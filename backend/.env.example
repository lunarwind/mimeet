APP_NAME=MiMeet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mimeet
DB_USERNAME=root
DB_PASSWORD=

# Cache / Session / Queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum (SPA auth)
# List all frontend domains, comma-separated, no http/https
# Local: localhost:5173,localhost:5174
# Production example: mimeet.tw,admin.mimeet.tw,api.mimeet.tw
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
SANCTUM_TOKEN_EXPIRATION=1440

# Broadcasting
BROADCAST_DRIVER=log

# Mail
# Use "log" for testing (no real email), "smtp" for production
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mimeet.tw"
MAIL_FROM_NAME="MiMeet"

# SMS
# provider: disabled / twilio / mitake
SMS_PROVIDER=disabled

# Twilio (if SMS_PROVIDER=twilio)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Mitake (if SMS_PROVIDER=mitake)
MITAKE_USERNAME=
MITAKE_PASSWORD=

# ECPay
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_IS_SANDBOX=true

# FCM Push Notification
FCM_SERVER_KEY=

# Admin accounts (CHANGE IN PRODUCTION!)
SUPER_ADMIN_EMAIL=super@mimeet.tw
SUPER_ADMIN_PASSWORD=change-me-in-production
ADMIN_EMAIL=admin@mimeet.tw
ADMIN_PASSWORD=change-me-in-production
CS_EMAIL=cs@mimeet.tw
CS_PASSWORD=change-me-in-production
