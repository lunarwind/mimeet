APP_NAME=MiMeet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Database ─────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mimeet
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / Session / Queue ──────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ─── Redis ────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Sanctum (SPA 認證) ──────────────────────
# 填入所有前端域名，逗號分隔，不含 http/https
# 本地開發：localhost:5173,localhost:5174
# 正式環境範例：mimeet.tw,admin.mimeet.tw,api.mimeet.tw
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
SANCTUM_TOKEN_EXPIRATION=1440

# ─── Broadcasting ─────────────────────────────
BROADCAST_DRIVER=log

# ─── Mail ─────────────────────────────────────
# 本地開發用 log（不發信，寫 log），正式用 smtp
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mimeet.tw"
MAIL_FROM_NAME="MiMeet"

# ─── SMS ──────────────────────────────────────
# provider: disabled / twilio / mitake
SMS_PROVIDER=disabled

# Twilio（若 SMS_PROVIDER=twilio）
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# 三竹 Mitake（若 SMS_PROVIDER=mitake）
MITAKE_USERNAME=
MITAKE_PASSWORD=

# ─── ECPay 綠界 ──────────────────────────────
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_IS_SANDBOX=true

# ─── FCM 推播 ────────────────────────────────
FCM_SERVER_KEY=

# ─── Admin 預設帳號（正式環境務必修改！）─────
SUPER_ADMIN_EMAIL=super@mimeet.tw
SUPER_ADMIN_PASSWORD=change-me-in-production
ADMIN_EMAIL=admin@mimeet.tw
ADMIN_PASSWORD=change-me-in-production
CS_EMAIL=cs@mimeet.tw
CS_PASSWORD=change-me-in-production
