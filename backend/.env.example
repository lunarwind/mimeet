APP_NAME=MiMeet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mimeet
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log

ECPAY_IS_SANDBOX=true

# Admin Accounts (change in production!)
SUPER_ADMIN_EMAIL=super@mimeet.tw
SUPER_ADMIN_PASSWORD=change-me-in-production
ADMIN_EMAIL=admin@mimeet.tw
ADMIN_PASSWORD=change-me-in-production
CS_EMAIL=cs@mimeet.tw
CS_PASSWORD=change-me-in-production
