# Environment files (never commit secrets)
.env
.env.local
.env.*.local
**/.env
**/.env.testing
**/.env.development
**/.env.production
!**/.env.example

node_modules/
vendor/
*.log
.DS_Store

# Firebase Service Account (NEVER commit private keys)
**/storage/app/firebase-service-account.json
**/*-service-account.json
**/firebase-credentials.json

.claude/

Fonts/

.idea/
.vscode/settings.json
*.swp
.DS_Store

# Laravel runtime cache artifacts (regenerated by `php artisan *:cache`)
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitkeep
